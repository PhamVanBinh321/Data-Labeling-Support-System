# =============================================================================
# PRODUCTION ENV TEMPLATE
# Copy file tương ứng vào từng service folder và điền giá trị thật
# VD: cp .env.production.example auth-service/.env
# =============================================================================
# Thay <VPS_IP> bằng IP thật của server, hoặc domain nếu có

# ─── AUTH SERVICE ─────────────────────────────────────────────────────────────
# File: auth-service/.env
SECRET_KEY=<random-50-chars>          # python -c "import secrets; print(secrets.token_urlsafe(50))"
DEBUG=False
ALLOWED_HOSTS=<VPS_IP>,localhost
DATABASE_URL=postgresql://auth_user:auth_pass@auth-db:5432/auth_db
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_SIGNING_KEY=<shared-random-50-chars>   # Phải giống nhau ở mọi service!
REDIS_URL=redis://redis:6379/0
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# ─── PROJECT SERVICE ──────────────────────────────────────────────────────────
# File: project-service/.env
SECRET_KEY=<random-50-chars>
DEBUG=False
ALLOWED_HOSTS=<VPS_IP>,localhost,project-service
DATABASE_URL=postgresql://project_user:project_pass@project-db:5432/project_db
AUTH_SERVICE_URL=http://auth-service:8001
NOTIFICATION_SERVICE_URL=http://notification-service:8005
JWT_SIGNING_KEY=<shared-random-50-chars>   # Phải giống auth-service
RABBITMQ_URL=amqp://dlss:<rabbitmq_password>@rabbitmq:5672/
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# ─── TASK SERVICE ─────────────────────────────────────────────────────────────
# File: task-service/.env
SECRET_KEY=<random-50-chars>
DEBUG=False
ALLOWED_HOSTS=<VPS_IP>,localhost,task-service
DATABASE_URL=postgresql://task_user:task_pass@task-db:5432/task_db
AUTH_SERVICE_URL=http://auth-service:8001
NOTIFICATION_SERVICE_URL=http://notification-service:8005
JWT_SIGNING_KEY=<shared-random-50-chars>   # Phải giống auth-service
RABBITMQ_URL=amqp://dlss:<rabbitmq_password>@rabbitmq:5672/
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# ─── ANNOTATION SERVICE ───────────────────────────────────────────────────────
# File: annotation-service/.env
SECRET_KEY=<random-50-chars>
DEBUG=False
ALLOWED_HOSTS=<VPS_IP>,localhost,annotation-service
DATABASE_URL=postgresql://annotation_user:annotation_pass@annotation-db:5432/annotation_db
AUTH_SERVICE_URL=http://auth-service:8001
TASK_SERVICE_URL=http://task-service:8003
MEDIA_ROOT=/media
JWT_SIGNING_KEY=<shared-random-50-chars>   # Phải giống auth-service
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=<minio_access_key>
MINIO_SECRET_KEY=<minio_secret_key>
MINIO_BUCKET=dlss-media
MINIO_PUBLIC_HOST=http://<VPS_IP>:9000     # ← URL công khai để client tải ảnh
MINIO_USE_SSL=False
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# ─── NOTIFICATION SERVICE ─────────────────────────────────────────────────────
# File: notification-service/.env
SECRET_KEY=<random-50-chars>
DEBUG=False
ALLOWED_HOSTS=<VPS_IP>,localhost,notification-service
DATABASE_URL=postgresql://notify_user:notify_pass@notification-db:5432/notify_db
AUTH_SERVICE_URL=http://auth-service:8001
JWT_SIGNING_KEY=<shared-random-50-chars>   # Phải giống auth-service
REDIS_URL=redis://redis:6379/1
RABBITMQ_URL=amqp://dlss:<rabbitmq_password>@rabbitmq:5672/
FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# ─── ADMIN SERVICE ────────────────────────────────────────────────────────────
# File: admin-service/.env
SECRET_KEY=<random-50-chars>
DEBUG=False
ALLOWED_HOSTS=<VPS_IP>,localhost,admin-service
DATABASE_URL=postgresql://reporting_user:reporting_pass@reporting-db:5432/reporting_db
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# ─── GENERATE SECRET KEYS (chạy lệnh này trên VPS) ───────────────────────────
# python -c "import secrets; print(secrets.token_urlsafe(50))"
