# ─── SHARED ──────────────────────────────────────────────────────────────────
# Copy file này thành .env trong mỗi service folder, rồi điền giá trị thật

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── AUTH SERVICE (.env) ─────────────────────────────────────────────────────
# DATABASE_URL=postgresql://auth_user:auth_pass@auth-db:5432/auth_db
# SECRET_KEY=auth-service-secret
# JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
# JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── PROJECT SERVICE (.env) ──────────────────────────────────────────────────
# DATABASE_URL=postgresql://project_user:project_pass@project-db:5432/project_db
# SECRET_KEY=project-service-secret
# AUTH_SERVICE_URL=http://auth-service:8001

# ─── TASK SERVICE (.env) ─────────────────────────────────────────────────────
# DATABASE_URL=postgresql://task_user:task_pass@task-db:5432/task_db
# SECRET_KEY=task-service-secret
# AUTH_SERVICE_URL=http://auth-service:8001
# NOTIFICATION_SERVICE_URL=http://notification-service:8005

# ─── ANNOTATION SERVICE (.env) ───────────────────────────────────────────────
# DATABASE_URL=postgresql://annotation_user:annotation_pass@annotation-db:5432/annotation_db
# SECRET_KEY=annotation-service-secret
# AUTH_SERVICE_URL=http://auth-service:8001
# TASK_SERVICE_URL=http://task-service:8003
# MEDIA_ROOT=/media

# ─── NOTIFICATION SERVICE (.env) ─────────────────────────────────────────────
# DATABASE_URL=postgresql://notify_user:notify_pass@notification-db:5432/notify_db
# SECRET_KEY=notification-service-secret
# AUTH_SERVICE_URL=http://auth-service:8001
# FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json  # (sau này)
